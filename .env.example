# ==============================================================================
# Logging Sub-Settings
# ==============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG__LEVEL=INFO

# Path to log file. Leave unset to disable file logging.
LOG__FILE_PATH=logs/app.logs

# Maximum log file size in bytes before rotation (default: 10 MB)
LOG__MAX_BYTES=10485760

# Number of rotated log file backups to keep
LOG__BACKUP_COUNT=5
# ==============================================================================

# ==============================================================================
# Database Sub-Settings
# ==============================================================================
# Async SQLAlchemy connection string.
# SQLite default: 'sqlite+aiosqlite:///./rag.db'.
# PostgreSQL example: 'postgresql+asyncpg://user:pass@host/db'.
DATABASE__URI=sqlite+aiosqlite:///./rag.db
# postgresql+asyncpg://raguser:password@localhost:5432/ragdb

# Set to true to log all SQL queries to stdout (useful for debugging):
DATABASE__ECHO_SQL=false
# ==============================================================================

# ==============================================================================
# Vector Store Sub-Settings
# ==============================================================================
VECTOR_STORE__COLLECTION_NAME=rag_documents

# HuggingFace model ID used to compute text vector profiles
VECTOR_STORE__EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

VECTOR_STORE__NORMALIZE_EMBEDDINGS=true

# Must be either path to a directory for storing Qdrant vector locally, or the
# URL of the vector store.
VECTOR_STORE__URL_OR_PATH=./.qdrant_local/
# Can also be: VECTOR_STORE__URL_OR_PATH=http://localhost:6333/

# Size of vector from embedding
VECTOR_STORE__VECTOR_SIZE=384

# TTL for embeddings on vectorstore in seconds (default: 24 hours).
VECTOR_STORE__TTL=86400

# Optional API key for Qdrant Cloud cluster connections.
# Only required if VECTOR_STORE__URL_OR_PATH points to a remote 'qdrant.tech'
# instance.
# VECTOR_STORE__API_KEY=your_qdrant_cloud_api_key_goes_here
# ==============================================================================

# ==============================================================================
# Text Chunking Sub-Settings
# ==============================================================================
# Huggingface model used for tokenizing a piece of text
TEXT_CHUNK__TOKENIZER_MODEL=BAAI/bge-large-en-v1.5

# Chunk size for each text chunk extracted from documents.
TEXT_CHUNK__CHUNK_SIZE=500

# Value must be strictly less than `TEXT_CHUNK__CHUNK_SIZE`
TEXT_CHUNK__CHUNK_OVERLAP=50
# ==============================================================================

# ==============================================================================
# Search Sub-Settings
# ==============================================================================
SEARCH__TOP_K=4

# Retrieval Options: "similarity", "mmr", "similarity_score_threshold"
SEARCH__SEARCH_TYPE=similarity

# Document retrieval confidence cutoff constraint (0.0 ≤ score_threshold ≤ 1.0).
# No need to set if `SEARCH__SEARCH_TYPE` is not "similarity_score_threshold".
SEARCH__SCORE_THRESHOLD=0.5

# Relevance control (0.0 ≤ lambda_mult ≤ 1.0).
# No need to set if `SEARCH__SEARCH_TYPE` is not "mmr".
SEARCH__LAMBDA_MULT=0.5
# ==============================================================================

# ==============================================================================
# LLM Sub-Settings
# ==============================================================================

# Maximum retries on LLM output generation before error is thrown
LLM__MAX_RETRIES=3

# Balance randomness and precision (0.0 ≤ temperature ≤ 1.0)
LLM__TEMPERATURE=0.1

# Maximum tokens of LLM output (≥1)
LLM__MAX_OUTPUT_TOKEN=1024

# Target inference model hosted on Groq (e.g., llama-3.3-70b-versatile)
LLM__MODEL_NAME=llama-3.3-70b-versatile

# Target LLM provider
# Current Providers: ['groq', 'openrouter']
LLM__PROVIDER=groq

# API key for LLM provider
LLM__API_KEY=your_actual_api_key

# ==============================================================================

# ==============================================================================
# Ingest Sub-Settings
# ==============================================================================
# Maximum file size in MB
INGEST__MAX_FILE_SIZE=50

# Preprocessing toggles for handling advanced layouts and document types
# (true/false)
INGEST__DO_OCR=false
INGEST__DO_TABLE_STRUCTURE=false
INGEST__GENERATE_PAGE_IMAGES=false

# Root toggle for graphic element parsing
INGEST__GENERATE_PICTURE_IMAGES=false

# NOTE: The two options below require INGEST__GENERATE_PICTURE_IMAGES=true.
# If INGEST__GENERATE_PICTURE_IMAGES is false, these will be silently forced
# to false at runtime.
INGEST__DO_PICTURE_CLASSIFICATION=false
INGEST__DO_PICTURE_DESCRIPTION=false
# ==============================================================================
